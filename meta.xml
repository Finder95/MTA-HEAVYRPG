<meta>
    <info author="OpenAI" name="HeavyRPG" description="Modularny gamemode RPG z zaawansowanym logowaniem/rejestracja CEF + SQLite" type="gamemode" version="0.1.0" />

    <!-- Shared -->
    <script src="shared/config.lua" type="shared" />
    <script src="shared/enums.lua" type="shared" />
    <script src="shared/utils.lua" type="shared" />

    <!-- Server core -->
    <script src="server/core/logger.lua" type="server" />
    <script src="server/core/database.lua" type="server" />
    <script src="server/core/security.lua" type="server" />
    <script src="server/core/module_loader.lua" type="server" />

    <!-- Server modules -->
    <script src="server/modules/auth/validators.lua" type="server" />
    <script src="server/modules/auth/repository.lua" type="server" />
    <script src="server/modules/auth/session.lua" type="server" />
    <script src="server/modules/character/main.lua" type="server" />
    <script src="server/modules/auth/main.lua" type="server" />
    <script src="server/modules/spawn/main.lua" type="server" />
    <script src="server/modules/survival/main.lua" type="server" />
    <script src="server/modules/bank/main.lua" type="server" />
    <script src="server/modules/inventory/main.lua" type="server" />

    <!-- Server bootstrap must be loaded after modules -->
    <script src="server/core/boot.lua" type="server" />

    <!-- Client core -->
    <script src="client/core/local_storage.lua" type="client" />
    <script src="client/core/browser.lua" type="client" />
    <script src="client/modules/auth/main.lua" type="client" />
    <script src="client/modules/character/main.lua" type="client" />
    <script src="client/modules/hud/main.lua" type="client" />
    <script src="client/modules/inventory/main.lua" type="client" />
    <script src="client/core/boot.lua" type="client" />

    <!-- CEF files -->
    <file src="html/auth/index.html" />
    <file src="html/auth/style.css" />
    <file src="html/auth/app.js" />
    <file src="html/character/index.html" />
    <file src="html/character/style.css" />
    <file src="html/character/app.js" />

    <!-- HUD sprites -->
    <file src="assets/hud/health.png" />
    <file src="assets/hud/armor.png" />
    <file src="assets/hud/hunger.png" />
    <file src="assets/hud/thirst.png" />
    <file src="assets/hud/energy.png" />
    <file src="assets/hud/hygiene.png" />
    <file src="assets/hud/stress.png" />

    <!-- SQLite folder placeholder -->
    <file src="data/.gitkeep" />

    <!-- Useful server exports for future RPG modules -->
    <export function="isPlayerAuthenticated" type="server" />
    <export function="getPlayerAccountId" type="server" />
    <export function="getPlayerAccountData" type="server" />
    <export function="getPlayerNeeds" type="server" />
    <export function="setPlayerNeed" type="server" />
    <export function="addPlayerNeed" type="server" />
    <export function="getPlayerBankBalance" type="server" />
    <export function="depositPlayerBankMoney" type="server" />
    <export function="withdrawPlayerBankMoney" type="server" />
    <export function="transferPlayerBankMoney" type="server" />
    <export function="getPlayerBankTransactions" type="server" />
    <export function="givePlayerInventoryItem" type="server" />
    <export function="takePlayerInventoryItem" type="server" />
    <export function="getPlayerInventoryItems" type="server" />
    <export function="getPlayerInventoryWeight" type="server" />
</meta>
